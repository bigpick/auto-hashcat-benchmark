# Vast.ai API key — get yours at https://cloud.vast.ai/manage-keys/
# VAST_API_KEY=

# Container registry (default: ghcr.io/YOUR_USERNAME/hashcat-bench)
# HASHCAT_BENCH_REGISTRY=ghcr.io/your-username/hashcat-bench

# CUDA version for container builds (default: 12.9.1)
# HASHCAT_BENCH_CUDA=12.9.1

# Path to SSH public key for Vast.ai instances (default: ~/.ssh/id_ed25519.pub)
# The corresponding private key is used for SSH connections.
# HASHCAT_BENCH_SSH_KEY=~/.ssh/id_ed25519.pub
